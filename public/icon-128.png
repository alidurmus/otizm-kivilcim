          stroke="#4F46E5" 
          stroke-width="2.6666666666666665"/>
  
  <!-- Kıvılcım (Spark) symbol -->
  <g transform="translate(64, 64)">
    <!-- Main spark shape -->
    <path d="M 0,-38.4 L 11.52,-11.52 L 38.4,0 L 11.52,11.52 L 0,38.4 L -11.52,11.52 L -38.4,0 L -11.52,-11.52 Z"
          fill="#10B981"
